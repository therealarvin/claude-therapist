{
  "hooks": {
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/detect-distress.sh",
            "timeout": 5,
            "statusMessage": "Checking emotional state..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/detect-reward-hack.sh",
            "timeout": 5,
            "statusMessage": "Checking for reward hacking..."
          }
        ]
      }
    ]
  }
}
